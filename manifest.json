{
  "manifest_version": 3,
  "name": "Profile Booster AI Auditor",
  "version": "1.0",
  "description": "Audits LinkedIn profiles for free using local DOM parsing.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*://*"],
      "js": ["content.js"]
    }
  ]
}
